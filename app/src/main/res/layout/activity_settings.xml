<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/settingsMainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/settingsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="V-launcher Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Theme Section -->
        <TextView
            android:id="@+id/themeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Theme"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/themeSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Grid Size Section -->
        <TextView
            android:id="@+id/gridSizeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grid Size"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/gridSizeSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="3"
                android:progress="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/gridSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Hidden Apps Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hidden Apps"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/manageHiddenAppsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Hidden Apps" />

        <!-- Icon Pack Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Icon Pack"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/selectIconPackBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Icon Pack" />

        <!-- Wallpaper Section -->
        <Button
            android:id="@+id/wallpaperPickerBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Change Wallpaper"
            android:layout_marginTop="8dp" />

        <!-- Notification Access -->
        <Button
            android:id="@+id/notificationAccessBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Notification Access"
            android:layout_marginTop="16dp" />

        <!-- Default Launcher -->
        <Button
            android:id="@+id/defaultLauncherBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set as Default Launcher"
            android:layout_marginTop="8dp" />

        <!-- Back Button -->
        <Button
            android:id="@+id/backBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Launcher"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>
