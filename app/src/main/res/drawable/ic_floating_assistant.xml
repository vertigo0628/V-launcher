<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="28dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#4400F0FF"
                android:endColor="#00000000" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <!-- Main circle -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FF00D4FF"
                android:endColor="#FF0066FF" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>
</layer-list>
