<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top glow line -->
    <item android:height="2dp" android:gravity="top">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/neon_cyan"
                android:centerColor="@color/neon_pink"
                android:endColor="@color/neon_purple"
                android:angle="0" />
        </shape>
    </item>
    <!-- Dark background -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_bg_secondary" />
        </shape>
    </item>
</layer-list>
