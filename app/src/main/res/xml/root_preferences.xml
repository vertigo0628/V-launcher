<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="General">
        <ListPreference
            app:defaultValue="dark"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:key="theme"
            app:title="Theme"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            app:defaultValue="4"
            app:entries="@array/grid_size_entries"
            app:entryValues="@array/grid_size_values"
            app:key="grid_size"
            app:title="Grid Size"
            app:useSimpleSummaryProvider="true" />
            
        <Preference
            app:key="wallpaper_picker"
            app:title="Change Wallpaper"
            app:summary="Set home screen wallpaper" />
            
    </PreferenceCategory>

    <PreferenceCategory app:title="Customization">
        <Preference
            app:key="icon_pack"
            app:title="Icon Pack"
            app:summary="Change app icons" />
            
        <Preference
            app:key="manage_hidden_apps"
            app:title="Hidden Apps"
            app:summary="Manage protected applications" />
            
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="show_labels"
            app:title="Show App Labels" />

        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="show_badges"
            app:title="Show Notification Badges"
            app:summary="Display unread counts on app icons" />
    </PreferenceCategory>

    <PreferenceCategory app:title="System">
        <Preference
            app:key="default_launcher"
            app:title="Set as Default Launcher"
            app:summary="Open system settings" />

        <Preference
            app:key="notification_access"
            app:title="Notification Access"
            app:summary="Enable for badges and smart features" />

        <Preference
            app:key="miui_autostart"
            app:title="MIUI AutoStart System"
            app:summary="Enable background processes and notifications" />

        <SwitchPreferenceCompat
            app:defaultValue="false"
            app:key="neural_nav_enabled"
            app:title="Neural Navigation"
            app:summary="Bypass Xiaomi gesture lock with invisible bridge" />
    </PreferenceCategory>

    <PreferenceCategory app:title="AI &amp; Voice">
        <SwitchPreferenceCompat
            app:defaultValue="false"
            app:key="floating_assistant_enabled"
            app:title="Floating Assistant"
            app:summary="Enable the floating AI dynamic island overlay" />
            
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="voice_assistant_enabled"
            app:title="Voice Assistant"
            app:summary="Always-on voice with SUNDAY wake word" />
            
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="neural_hub_enabled"
            app:title="Neural Hub"
            app:summary="Background system monitoring" />
            
        <EditTextPreference
            app:defaultValue="http://127.0.0.1:11434"
            app:key="ollama_base_url"
            app:title="AI Base URL"
            app:summary="Address of your Ollama server (Local or Cloud)"
            app:useSimpleSummaryProvider="true" />
            
        <Preference
            app:key="ollama_model_select"
            app:title="AI Brain Model"
            app:summary="Select the local or cloud model to use" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Aesthetic &amp; Gestures">
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="scribble_search_enabled"
            app:title="Scribble Search"
            app:summary="Draw letters on home screen to search apps" />
            
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="weather_particles_enabled"
            app:title="Weather Particle Wallpaper"
            app:summary="Dynamic particles matching local weather" />
            
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="edge_panel_enabled"
            app:title="Edge Swipe Panel"
            app:summary="Slide-out drawer for favorites, toggles, and calculator" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Shizuku Power">
        <Preference
            app:key="shizuku_manager"
            app:title="Shizuku Status"
            app:summary="Manage ADB-level shell permissions" />
            
        <Preference
            app:key="shizuku_permission_manager"
            app:title="System Permission Manager"
            app:summary="Grant/Revoke permissions for any app" />
            
        <Preference
            app:key="shizuku_frozen_manager"
            app:title="Frozen Apps Manager"
            app:summary="List and manage disabled system apps" />

        <Preference
            app:key="file_hunter"
            app:title="File Hunter"
            app:summary="Browse and manage restricted data modules" />

        <Preference
            app:key="reignite_services"
            app:title="🚀 RE-IGNITE SERVICES"
            app:summary="Fix Music &amp; Boost after package change" />

        <Preference
            app:key="system_kill_switch"
            app:title="💀 System Kill Switch"
            app:summary="Force stop all apps &amp; activities (Soft Reboot)" />
    </PreferenceCategory>

</PreferenceScreen>
