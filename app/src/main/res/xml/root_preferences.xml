<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="General">
        <ListPreference
            app:defaultValue="light"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:key="theme"
            app:title="Theme"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            app:defaultValue="4"
            app:entries="@array/grid_size_entries"
            app:entryValues="@array/grid_size_values"
            app:key="grid_size"
            app:title="Grid Size"
            app:useSimpleSummaryProvider="true" />
            
        <Preference
            app:key="wallpaper_picker"
            app:title="Change Wallpaper"
            app:summary="Set home screen wallpaper" />
            
    </PreferenceCategory>

    <PreferenceCategory app:title="Customization">
        <Preference
            app:key="icon_pack"
            app:title="Icon Pack"
            app:summary="Change app icons" />
            
        <Preference
            app:key="manage_hidden_apps"
            app:title="Hidden Apps"
            app:summary="Manage protected applications" />
            
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="show_labels"
            app:title="Show App Labels" />
    </PreferenceCategory>

    <PreferenceCategory app:title="System">
        <Preference
            app:key="default_launcher"
            app:title="Set as Default Launcher"
            app:summary="Open system settings" />

        <Preference
            app:key="notification_access"
            app:title="Notification Access"
            app:summary="Enable for badges and smart features" />
    </PreferenceCategory>

</PreferenceScreen>
